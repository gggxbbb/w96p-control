{
  "name": "@gggxbbb/w96p-cli",
  "version": "0.2.1",
  "private": false,
  "description": "W96P/W66D BLE 风扇调试工具（TUI + MCP server）",
  "homepage": "https://github.com/gggxbbb/w96p-control/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/gggxbbb/w96p-control/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gggxbbb/w96p-control.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "gggxbbb",
  "type": "module",
  "bin": {
    "w96p-cli": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/main.tsx",
    "build": "esbuild src/main.tsx --bundle --platform=node --format=esm --target=node20 --banner:js=\"#!/usr/bin/env node\" --outfile=dist/cli.mjs --external:webbluetooth --external:ink --external:ink-text-input --external:react --external:@modelcontextprotocol/sdk",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@gggxbbb/w96p-ble-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ink": "^7.1.1",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "webbluetooth": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/web-bluetooth": "^0.0.21",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
